{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enterprise Whitebox Gold Set",
  "type": "object",
  "required": [
    "schema",
    "schema_version",
    "repo_id",
    "repo_description",
    "profile",
    "review_date",
    "reviewers",
    "human_ground_truth_findings",
    "human_top_blockers",
    "required_human_reviews",
    "manual_review_time_minutes",
    "notes"
  ],
  "properties": {
    "schema": { "const": "enterprise-whitebox-goldset" },
    "schema_version": { "const": "0.1" },
    "repo_id": { "type": "string" },
    "repo_description": { "type": "string" },
    "profile": {
      "type": "string",
      "enum": ["enterprise", "finance-sox", "production-critical", "ai-enabled", "sandbox", "team-use", "department-use"]
    },
    "review_date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "reviewers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["reviewer_id", "role"],
        "properties": {
          "reviewer_id": { "type": "string" },
          "role": {
            "type": "string",
            "enum": ["AppSec", "CISO", "CTO", "Architecture", "DevOps", "SOX", "ITGC", "Legal", "Privacy", "Other"]
          }
        },
        "additionalProperties": false
      }
    },
    "human_ground_truth_findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "human_finding_id",
          "domain",
          "rule_id",
          "severity",
          "title",
          "description",
          "file_path",
          "evidence_hint",
          "decision_impact",
          "materiality",
          "expected_scanner_detectable"
        ],
        "properties": {
          "human_finding_id": { "type": "string" },
          "domain": { "type": "string" },
          "rule_id": { "type": ["string", "null"] },
          "severity": { "type": "string", "enum": ["Critical", "High", "Medium", "Low", "Info"] },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "file_path": { "type": ["string", "null"] },
          "evidence_hint": { "type": ["string", "null"] },
          "decision_impact": { "type": "string", "enum": ["Block", "Mandatory Review", "Conditional", "Advisory"] },
          "materiality": { "type": "string", "enum": ["material", "minor", "informational"] },
          "expected_scanner_detectable": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "human_top_blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["blocker_id", "title", "domain", "severity", "decision_impact"],
        "properties": {
          "blocker_id": { "type": "string" },
          "title": { "type": "string" },
          "domain": { "type": "string" },
          "severity": { "type": "string", "enum": ["Critical", "High"] },
          "decision_impact": { "type": "string", "enum": ["Block", "Mandatory Review"] }
        },
        "additionalProperties": false
      }
    },
    "required_human_reviews": { "type": "array" },
    "manual_review_time_minutes": { "type": "number", "minimum": 0 },
    "notes": { "type": "array" }
  },
  "additionalProperties": false
}
