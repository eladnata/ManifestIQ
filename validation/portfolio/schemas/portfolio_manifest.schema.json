{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enterprise Whitebox Validation Portfolio Manifest",
  "type": "object",
  "required": ["schema", "schema_version", "portfolio_id", "description", "created_at", "scanner_version", "ruleset_version", "comparison_reports"],
  "properties": {
    "schema": { "const": "enterprise-whitebox-validation-portfolio" },
    "schema_version": { "const": "0.1" },
    "portfolio_id": { "type": "string" },
    "description": { "type": "string" },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "scanner_version": { "type": "string" },
    "ruleset_version": { "type": "string" },
    "comparison_reports": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["repo_id", "profile", "comparison_report_path", "worksheet_path", "triage_path"],
        "properties": {
          "repo_id": { "type": "string" },
          "profile": {
            "type": "string",
            "enum": ["enterprise", "finance-sox", "production-critical", "ai-enabled", "sandbox", "team-use", "department-use"]
          },
          "comparison_report_path": { "type": "string" },
          "worksheet_path": { "type": ["string", "null"] },
          "triage_path": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
