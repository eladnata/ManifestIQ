{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Enterprise Whitebox Validation Trend Manifest",
  "type": "object",
  "required": ["schema", "schema_version", "trend_id", "description", "baseline_report_path", "candidate_report_path", "comparison_mode", "created_at"],
  "properties": {
    "schema": { "const": "enterprise-whitebox-validation-trend-manifest" },
    "schema_version": { "const": "0.1" },
    "trend_id": { "type": "string" },
    "description": { "type": "string" },
    "baseline_report_path": { "type": "string" },
    "candidate_report_path": { "type": "string" },
    "comparison_mode": { "const": "baseline_vs_candidate" },
    "created_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
  },
  "additionalProperties": false
}
